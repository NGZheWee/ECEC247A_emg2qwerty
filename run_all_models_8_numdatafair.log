  _target_: emg2qwerty.lightning.DataFractionWindowedEMGDataModule
  window_length: 8000
  padding:
  - 1800
  - 200
  train_fraction: 0.25
optimizer:
  _target_: torch.optim.Adam
  lr: 0.001
lr_scheduler:
  scheduler:
    _target_: pl_bolts.optimizers.lr_scheduler.LinearWarmupCosineAnnealingLR
